  "passiveTalents": [
    {
      "name": "Tag-Team Triple Jump!",
      "description": "After using the Elemental Skill Riding the Night-Rainbow, Varesa gains \"Rainbow Crash\" for 5s.\nDuring this time, when Varesa uses a Plunging Attack, the shockwave DMG dealt when she hits the ground is increased by 50% of her ATK. If Varesa is in the Fiery Passion state, this ground impact DMG is increased by 180% of her ATK instead.\n\nThe Rainbow Crash effect will be canceled once a ground impact hits an opponent, or when its duration expires.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Varesa_05.png"
    },
    {
      "name": "The Hero Twice-Returned!",
      "description": "When a nearby party member triggers a Nightsoul Burst, Varesa's ATK increases by 35% for 12s. Max 2 stacks. Each stack's duration is counted independently.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Varesa_06.png"
    },
    {
      "name": "Night Realm's Gift: A Torch That Incinerates Evil",
      "description": "After Nightsoul points have been fully depleted, Varesa will switch to using Phlogiston to maintain the Sudden Onrush mode from her Nightsoul's Blessing.\nWhile in an area with Phlogiston Mechanics within Natlan, Nightsoul Transmission: Varesa can be used. When the current active character is sprinting or in movement modes caused by certain Talents, or at a certain height in the air, switching to Varesa will trigger the following: Varesa enters the Nightsoul's Blessing state, switches to Sudden Onrush mode, and obtains 20 Nightsoul points. Nightsoul Transmission can be triggered once every 10s by your own party.\nWhile in an area with Phlogiston Mechanics within Natlan, Varesa will not take fall DMG when using terrain differences to make leaps.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Varesa_07.png"
    },
    {
      "name": "Blazing Heart, Singular Advance!",
      "description": "Varesa's Sprint speed is increased. When she is not in combat, her Sprint Stamina consumption will also increase.\nAdditionally, while in an area with Phlogiston Mechanics within Natlan, your party members will restore 20 Phlogiston when consuming food. This effect can occur once every 10s and does not take effect in Domains, Trounce Domains, or the Spiral Abyss.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Varesa_08.png"
    }
  ],
  "constellations": [
    {
      "name": "Undying Passion",
      "description": "The effects of the Ascension Talent \"Tag-Team Triple Jump!\" are enhanced:\nWhen performing the Special Plunging Attack \"Thunderous Tornado Eruption,\" Varesa will also gain \"Rainbow Crash\" for 5s.\nWhen \"Rainbow Crash\" is in effect, Varesa's Plunging Attack ground impact DMG is increased by 180% of her ATK, whether she is in the Fiery Passion state or not. You must first unlock the Ascension Talent \"Tag-Team Triple Jump!\" to access the above effect.\n\nAdditionally, when Varesa is in the Sudden Onrush mode of her Nightsoul's Blessing, she consumes 30% less Nightsoul points or Phlogiston.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Varesa_01.png"
    },
    {
      "name": "Beyond the Edge of Light",
      "description": "Varesa will enter Apex Drive after using a Plunging Attack, regardless of whether she is in the Fiery Passion state or not.\nWhen Apex Drive is active, Varesa's interruption resistance will also further increase.\nAdditionally, Varesa will restore 11.5 Energy when her Plunging Attack ground impact hits an opponent.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Varesa_02.png"
    },
    {
      "name": "Unbowed Resolve",
      "description": "Increases the Level of Guardian Vent! by 3.\nMaximum upgrade level is 15.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_U_Varesa_01.png"
    },
    {
      "name": "The Courage to Press On",
      "description": "Varesa will receive various buffs based on her state when using her Elemental Burst Guardian Vent! If Varesa:\n· Has neither Fiery Passion nor Apex Drive active, she will gain Diligent Refinement for 15s, which will increase her Plunging Attack ground impact DMG by 500% of her ATK, with a maximum increase of 20,000 DMG. This effect will be canceled once the ground impact hits an opponent, or if its duration ends.\n· If she has either Fiery Passion or Apex Drive active, this instance of her Elemental Burst Guardian Vent! deals 100% increased DMG.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Varesa_03.png"
    },
    {
      "name": "Thoughts Floating on the Warm Breeze",
      "description": "Increases the Level of Normal Attack: By the Horns by 3.\nMaximum upgrade level is 15.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_U_Varesa_02.png"
    },
    {
      "name": "A Hero of Justice's Triumph",
      "description": "Varesa restores 30 Energy when she enters Apex Drive.\nHer Plunging Attacks and Elemental Burst Guardian Vent! gain 10% CRIT Rate and 100% CRIT DMG.\nAdditionally, when Varesa uses the Hold version of her Elemental Skill Riding the Night-Rainbow, or Taps her Elemental Skill while in the Sudden Onrush mode, she will restore Nightsoul points up to her maximum.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Varesa_04.png"
    }
  ],
