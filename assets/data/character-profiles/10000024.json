  "passiveTalents": [
    {
      "name": "Retribution",
      "description": "Counterattacking with Tidecaller at the precise moment when the character is hit grants the maximum DMG Bonus.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Beidou_05.png"
    },
    {
      "name": "Lightning Storm",
      "description": "Gain the following effects for 10s after unleashing Tidecaller with its maximum DMG Bonus: \n·DMG dealt by Normal and Charged Attacks is increased by 15%. ATK SPD of Normal and Charged Attacks is increased by 15%.\n·Greatly reduced delay before unleashing Charged Attacks.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Beidou_06.png"
    },
    {
      "name": "Conqueror of Tides",
      "description": "Decreases swimming Stamina consumption for your own party members by 20%.\nNot stackable with Passive Talents that provide the exact same effects.",
