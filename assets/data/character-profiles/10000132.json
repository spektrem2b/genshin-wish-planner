  "passiveTalents": [
    {
      "name": "Verdict and Punishment",
      "description": "During the Elemental Burst The Bell Tolls! The Hunt Is On!, after the Witchlure Bell in Hunter-Seeker mode deals DMG to an opponent, if this DMG triggers Swirl on an opponent, it will also summon a Banehunter Oathhammer that will deal 150% of Prune's ATK as DMG to them, with the DMG Type matching the Elemental Conversion from the Swirl. This DMG is considered Elemental Burst DMG.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Prune_05.png"
    },
    {
      "name": "Tolling Synchronicity",
      "description": "After Prune hits an opponent with the Banehunter Oathhammer that has undergone Elemental Conversion, other nearby party members will gain the Tolling Rally effect for 5s: When Normal, Charged, or Plunging Attacks, or Elemental Skills and Bursts deal DMG to opponents, that attack's DMG will be increased based on the portion of Prune's ATK in excess of 2,000 when they become affected by the Tolling Rally effect. Every excess ATK point increases that instance of DMG by 0.025%, up to a total of 50% max.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Prune_06.png"
    },
    {
      "name": "Tinker-Tink, Clank, and Bang!",
      "description": "Has a 10% chance to get 1 regional Character Talent Material (base material excluded) when crafting. The rarity is the same as the resulting material.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Prune_08.png"
    },
    {
      "name": "Witch's Eve Rite: Witchseeker's Vow",
      "description": "After completing Witch's Homework: Of What Is Contested, Prune becomes a Hexerei character. When the party includes at least 2 Hexerei characters, you gain the Hexerei: Secret Rite effect, which enhances Hexerei characters.\n\nHexerei: Secret Rite\nAfter a Hexerei character in the party affected by the Tolling Rally effect triggers an Elemental Reaction on an opponent, Prune's ATK is increased by 60% for 5s. If the Elemental Reaction triggered is a Swirl Reaction, the triggering character's ATK will additionally be increased by 30% for 5s.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Prune_07.png"
    }
  ],
  "constellations": [
    {
      "name": "With a Vow to Rescue, the Journey Begins",
      "description": "After the Banehunter Oathhammer that has undergone Elemental Conversion hits an opponent, Prune will regain 2 Energy. This effect can occur once every 1.8s.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Prune_01.png"
    },
    {
      "name": "Useful for Cleaning Messy Baggage, Elemental Powers Are Indeed",
      "description": "During the Elemental Burst The Bell Tolls! The Hunt Is On!, when the Witchlure Bell is in Hunter-Seeker mode, Prune gains the Hunt the Witch effect: Prune's ATK increases by 10%, and when the Witchlure Bell and the Banehunter Oathhammer that has undergone Elemental Conversion hits an opponent, it further increases her ATK by 5%. Prune's ATK can be increased by up to 40% in this way.\nThe original instance of the above effect will be removed if \"The Bell Tolls! The Hunt Is On!\" is used again during this time.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Prune_02.png"
    },
    {
      "name": "The Caravan Exits the Mountain Pass, the Scenery Once More Changed",
      "description": "Increases the Level of The Bell Tolls! The Hunt Is On! by 3.\nMaximum upgrade level is 15.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_U_Prune_01.png"
    },
    {
      "name": "Looking Back Following the Wind, One's Shadow Still Halved",
      "description": "After the Banehunter Oathhammer that has undergone Elemental Conversion hits an opponent, it will ricochet and land on a nearby opponent, dealing 80% ATK as DMG of the corresponding Elemental Type.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Prune_03.png"
    },
    {
      "name": "100 Defeats? No Problem, Tomorrow, We Go Again",
      "description": "Increases the Level of Ring-A-Ding-Ding! Hexhunter Chime by 3.\nMaximum upgrade level is 15.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_U_Prune_02.png"
    },
    {
      "name": "And That's the Story! Share It With Your Friends!",
      "description": "The duration of the Witchlure Bell's Hunter-Seeker mode from the Elemental Burst The Bell Tolls! The Hunt Is On! is extended by 4s.\nAdditionally, after party members affected by Tolling Rally trigger any Elemental Reaction, they will cause Prune and the other current active character(s) affected by Tolling Rally to gain 350 ATK for 5s.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Prune_04.png"
    }
  ],
