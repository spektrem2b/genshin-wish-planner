  "passiveTalents": [
    {
      "name": "Cold-Blooded Strike",
      "description": "Every hit with Frostgnaw regenerates HP for Kaeya equal to 15% of his ATK.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Kaeya_05.png"
    },
    {
      "name": "Glacial Heart",
      "description": "Opponents Frozen by Frostgnaw will drop additional Elemental Particles.\nFrostgnaw may only produce a maximum of 2 additional Elemental Particles per use.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Kaeya_06.png"
    },
    {
      "name": "Hidden Strength",
      "description": "Decreases sprinting Stamina consumption for your own party members by 20%.\nNot stackable with Passive Talents that provide the exact same effects.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_Explosion_Sprint.png"
    }
  ],
  "constellations": [
    {
      "name": "Excellent Blood",
      "description": "The CRIT Rate of Kaeya's Normal and Charge Attacks against opponents affected by Cryo is increased by 15%.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Kaeya_01.png"
    },
    {
      "name": "Never-Ending Performance",
      "description": "While Glacial Waltz is in effect, for each opponent defeated, its duration is increased by 2.5s, up to a maximum of 15s.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Kaeya_02.png"
    },
