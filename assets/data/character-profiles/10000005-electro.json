  "passiveTalents": [
    {
      "name": "Thunderflash",
      "description": "When another nearby character in the party obtains an Abundance Amulet created by Lightning Blade, Lightning Blade's CD is decreased by 1.5s.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_PlayerElectric_05.png"
    },
    {
      "name": "Resounding Roar",
      "description": "Increases the Energy Recharge effect granted by Lightning Blade's Abundance Amulet by 10% of the Traveler's Energy Recharge.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_PlayerElectric_06.png"
    },
    {
      "name": "Foreign Thundertrail",
      "description": "Draw new strength from journeys past. For every element you have resonated with, you gain additional buffs.\n\nIn addition, when nearby party members unleash an Elemental Burst, Traveler will receive 1 stack of Blade of Resounding Thunder, max 3 stacks. After obtaining 3 stacks of Blade of Resounding Thunder, performing a Charged Attack will consume all stacks of Blade of Resounding Thunder and transform into the special Charged Attack: Detonate.\n\nCharged Attack: Detonate\n· Each Charged Attack hit deals increased Electro DMG. Increase in DMG is equal to 100% of Traveler's ATK. \n· 3s after hitting the enemy, 1 additional lightning strike will be triggered, dealing Electro DMG equal to 200% of Traveler's ATK. 1 Abundance Amulet will also be created. This DMG is considered Charged Attack DMG.\n· Charged Attack: Detonate can be triggered up to once every 15s.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_PlayerElectric_07.png"
    }
  ],
