  "passiveTalents": [
    {
      "name": "Overclocking Circuit",
      "description": "If there are thunderclouds created by Lunar-Charged reactions nearby when Birgitta unleashes Discharge attacks, she will initiate an additional attack, dealing AoE Electro DMG equal to 65% of Ineffa's ATK. This DMG is considered Lunar-Charged DMG.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Ineffa_05.png"
    },
    {
      "name": "Panoramic Permutation Protocol",
      "description": "When using the Elemental Burst Supreme Instruction: Cyclonic Exterminator, all your party members will gain the Parameter Permutation effect: Increases Ineffa and your own active party member's Elemental Mastery by 6% of Ineffa's ATK for 20s.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Ineffa_06.png"
    },
    {
      "name": "Moonsign Benediction: Assemblage Hub",
      "description": "When a party member triggers an Electro-Charged reaction, it will be converted into the Lunar-Charged reaction, with every 100 ATK that Ineffa has increasing Lunar-Charged's Base DMG by 0.7%, up to a maximum of 14%.\n\nAdditionally, when Ineffa is in the party, the party's Moonsign will increase by 1 level.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Ineffa_07.png"
    },
    {
      "name": "Flavor Synthesis Unit",
