  "passiveTalents": [
    {
      "name": "Better to Salivate Than Medicate",
      "description": "After using the Elemental Burst Scoring Cuts, Escoffier will obtain the Rehab Diet effect for 9s: Restores HP for nearby active characters every 1s based on 138.24% of Escoffier's ATK.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Escoffier_05.png"
    },
    {
      "name": "Inspiration-Immersed Seasoning",
      "description": "When there are 1/2/3/4 Hydro or Cryo characters in the party, Escoffier will decrease the Hydro RES and Cryo RES of any opponents hit by her Elemental Skill, Low-Temperature Cooking, or her Elemental Burst, Scoring Cuts, by 5%/10%/15%/55% for 12s.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Escoffier_06.png"
    },
    {
      "name": "Constant Off-the-Cuff Cookery",
      "description": "#When using the Hold form of her Elemental Skill Low-Temperature Cooking, Escoffier will activate her All-Spectrum Multi-Use Cooking Mek in its Off-the-Cuff Cookery mode.\n\nCooking Mek: Off-the-Cuff Cookery Mode\n· Places the Cooking Mek on the field. The Cooking Mek can absorb elemental attacks. When the absorbed elemental energy hits a certain limit, Escoffier can convert the ingredients placed within it into wonderful food.\n· Escoffier needs time to purchase new ingredients, so she can only make a certain number of dishes like this each week. The number of dishes Escoffier can make resets every Monday at 4:00 AM {TIMEZONE}.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Escoffier_08.png"
    }
