    },
    {
      "name": "Scholarly Blade",
      "description": "For every point of Elemental Mastery Tighnari possesses, his Charged Attack and Fashioner's Tanglevine Shaft DMG are increased by 0.06%.\nThe maximum DMG Bonus obtainable this way is 60%.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Tighnari_06.png"
    },
    {
