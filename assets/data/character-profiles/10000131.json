  "passiveTalents": [
    {
      "name": "Methexis",
      "description": "For 20s after unleashing the Elemental Skill Revelation: Uncreated Light, Nicole will continuously \"observe\" the other current active party members. After the observed character has remained on the field for 3s, their Grace of Kenosis is upgraded to Guidance of Theosis, increasing their ATK by an additional 300. If the observed character is a Hexerei character, Grace of Kenosis is upgraded to Guidance of Theosis straight away.\nWhen characters other than Nicole who have Guidance of Theosis leave the field, their effect reverts to Grace of Kenosis.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Nicole_05.png"
    },
    {
      "name": "Philokalia",
      "description": "When Elemental DMG from nearby active party members hits an opponent, Nicole's own Grace of Kenosis effect is upgraded to Guidance of Theosis for 8s.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Nicole_06.png"
    },
    {
      "name": "Nepsis",
      "description": "When you are in Teyvat and not in combat, Nicole's Charged Attack becomes \"Emissarial Guidance\" if you have already obtained the current region's Treasure Compass. Emissarial Guidance: Calls upon nearby Seelie to show the way, triggering an effect similar to the region's Treasure Compass.\nThis effect has a cooldown time of 5 seconds and does not work in Domains, Trounce Domains, and the Spiral Abyss.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Nicole_08.png"
    },
    {
      "name": "Witch's Eve Rite: Light in the Darkness",
      "description": "After completing Witch's Homework: The Role of a Guide...?, Nicole becomes a Hexerei character. When the party includes at least 2 Hexerei characters, you gain the Hexerei: Secret Rite effect, which enhances Hexerei characters.\n\nHexerei: Secret Rite\nIncreases the DMG dealt by Hexerei characters' Arcane Projections by 300% of Nicole's ATK.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Nicole_07.png"
    }
  ],
  "constellations": [
    {
      "name": "\"Do Not Be Afraid, Child Who Is Loved\"",
      "description": "When the current active character of your own in the party hits an opponent, an additional special \"Arcane Projection: Unity\" will be summoned to perform a Coordinated Attack against the opponent, dealing AoE Elemental DMG of the character's corresponding Elemental Type at 600% of their ATK. This DMG will be considered as having been dealt by the corresponding character.\nThis effect can trigger once every 6s.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Nicole_01.png"
    },
    {
      "name": "\"I Will Guide You and Show You the Path You Should Tread\"",
      "description": "Enhances the effects of the Elemental Skill Revelation: Uncreated Light: Grace of Kenosis increases ATK by an additional 300 (which does not count toward this effect's ATK Bonus limit), while Guidance of Theosis decreases nearby opponents' Elemental RES based on the corresponding character's Elemental Type by 25%. This effect does not stack for the same Element.\nAdditionally, when Nicole unleashes her Elemental Skill Revelation: Uncreated Light, nearby active party members will also gain a Shield of Blazing Light.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Nicole_02.png"
    },
    {
      "name": "\"A Lamp by Your Side, A Light to Shine the Way\"",
      "description": "Increases the Level of Revelation: Uncreated Light by 3.\nMaximum upgrade level is 15.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_U_Nicole_01.png"
    },
    {
      "name": "\"Whether Left or Right, No Matter Which Way You Turn\"",
      "description": "When nearby party members have their Grace of Kenosis upgraded to Guidance of Theosis, Nicole also bestows upon them the Pathfinder's Blessing effect for 20s. Each character can gain this effect once every 16s.\nThe Normal Attack, Charged Attack, Plunging Attack, Elemental Skill, and Elemental Burst DMG of characters with Pathfinder's Blessing is increased by 70% of Nicole's ATK. This effect will be removed once it has taken effect 8 times or when its duration is over.\nWhen multiple opponents are hit at once, instances of Pathfinder's Blessing are consumed equal to the number of opponents hit. Each character's Pathfinder's Blessing is counted independently.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Nicole_03.png"
    },
    {
      "name": "\"You Will Hear My Voice Beside You\"",
      "description": "Increases the Level of Revelation: Ladder of Divine Ascent by 3.\nMaximum upgrade level is 15.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_U_Nicole_02.png"
    },
    {
      "name": "\"This Is the Path, Walk It Without Delay\"",
      "description": "When Nicole's Grace of Kenosis is upgraded to Guidance of Theosis, all nearby party members' Grace of Kenosis will also be upgraded to Guidance of Theosis. Once upgraded, Guidance of Theosis will no longer revert to Grace of Kenosis.\nAdditionally, DMG dealt by characters with Guidance of Theosis will ignore 40% of opponents' DEF.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Nicole_04.png"
    }
  ],
