  "passiveTalents": [
    {
      "name": "The Selenic Adeptus Descends",
      "description": "When casting the Elemental Skill Heaven and Earth Made Manifest, or when nearby party members trigger Moondrift Harmony, Zibai gains the Selenic Descent effect for 4s: The DMG dealt by the 2nd hit of Spirit Steed's Stride is increased by 60% of Zibai's DEF.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Zibai_05.png"
    },
    {
      "name": "Layered Peaks Pierce the Clouds",
      "description": "Other Geo party members increase Zibai's DEF by 15% each. Hydro party members increase her Elemental Mastery by 60 each.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Zibai_06.png"
    },
    {
      "name": "Moonsign Benediction: The Coursing Sun and Moon",
      "description": "When a party member triggers a Hydro Crystallize reaction, it will be converted into the Lunar-Crystallize reaction, with every 100 DEF that Zibai has increasing Lunar-Crystallize's Base DMG by 0.7%, up to a maximum of 14%.\n\nAdditionally, when Zibai is in the party, the party's Moonsign will increase by 1 level.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Zibai_07.png"
    },
    {
      "name": "Moonlit Flower Forest",
      "description": "At night (18:00 – 06:00), when not in combat, restore 1 Elemental Energy to Zibai every 2 seconds.\nThis effect does not work in Domains, Trounce Domains, or the Spiral Abyss.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Zibai_08.png"
    }
  ],
  "constellations": [
    {
      "name": "Burst Forth With Vigor, But Enter in Silence",
      "description": "After using the Elemental Skill Heaven and Earth Made Manifest, Zibai will immediately gain 100 Phase Shift Radiance, and the max number of Spirit Steed's Stride usages per Lunar Phase Shift mode is increased to 5 times.\nAdditionally, each time you switch to the Lunar Phase Shift mode, the first Spirit Steed's Stride's 2nd-hit Lunar-Crystallize Reaction DMG is increased by 220%.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Zibai_01.png"
    },
    {
      "name": "At Birth Are Souls Born, and in Death Leave But Husks",
      "description": "When in the Lunar Phase Shift mode, all nearby party members' Lunar-Crystallize Reaction DMG is increased by 30%.\n\nMoonsign: Ascendant Gleam: Ascension Talent The Selenic Adeptus Descends is enhanced: the DMG dealt by the 2nd hit of Spirit Steed's Stride is further increased by 550% of Zibai's DEF. You must first unlock the Ascension Talent \"The Selenic Adeptus Descends.\"",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Zibai_02.png"
    },
    {
      "name": "Free From Constraints and Worldly Ties",
      "description": "Increases the Level of Elemental Skill Heaven and Earth Made Manifest by 3.\nMaximum upgrade level is 15.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_U_Zibai_01.png"
    },
    {
      "name": "The Spirit Passes, Then Form Follows",
      "description": "While in the Lunar Phase Shift mode, Zibai's Normal Attack sequence will not reset, and when Spirit Steed's Stride hits opponents, Zibai will gain the \"Scattermoon Splendor\" effect: The next time she uses Normal Attacks, the additional attack from her 4th hit will deal 250% of the original damage as Lunar-Crystallize Reaction DMG.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Zibai_03.png"
    },
    {
      "name": "Perceive the Worthless and Debate It Not",
      "description": "Increases the Level of Tri-Sphere Eminence by 3.\nMaximum upgrade level is 15.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_U_Zibai_02.png"
    },
    {
      "name": "The World, A Journey in Passing",
      "description": "While Zibai is in the Lunar Phase Shift mode, her Phase Shift Radiance gain rate is increased by 50%.\nAdditionally, Spirit Steed's Stride will change such that it will consume all Phase Shift Radiance. This will elevate the DMG dealt by this instance of Spirit Steed's Stride and the Lunar-Crystallize Reaction DMG dealt by Zibai within the next 3s by 1.6% for every point consumed above 70. This effect cannot stack.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Zibai_04.png"
    }
  ],
