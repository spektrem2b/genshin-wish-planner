  "passiveTalents": [
    {
      "name": "Spotless Waters",
      "description": "After the Dewdrop fired by the Hold Mode of the Aquacrest Saber hits an opponent, a Sourcewater Droplet will be generated near to the Traveler. If the Traveler picks it up, they will restore 7% HP.\n1 Droplet can be created this way every second, and each use of Aquacrest Saber can create 4 Droplets at most.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_PlayerWater_05.png"
    },
    {
      "name": "Clear Waters",
      "description": "If HP has been consumed via Suffusion while using the Hold Mode Aquacrest Saber, the Torrent Surge at the skill's end will deal Bonus DMG equal to 45% of the total HP the Traveler has consumed in this skill use via Suffusion.\nThe maximum DMG Bonus that can be gained this way is 5,000.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_PlayerWater_06.png"
    },
    {
      "name": "Foreign Aqualis",
      "description": "Draw new strength from journeys past. For every element you have resonated with, you gain additional buffs.\n\nAdditionally, when nearby party members' current HP increases or decreases by 5%, Traveler will receive 1 stack of Blade of Many Waters. You can gain 1 stack of Blade of Many Waters this way once every 4s, max 3 stacks. After obtaining 3 stacks of Blade of Many Waters, performing a Charged Attack will consume all stacks of Blade of Many Waters and transform into the special Charged Attack: Tidebound.\n\nCharged Attack: Tidebound\n· Each Charged Attack hit deals increased Hydro DMG. Increase in DMG is equal to 150% of Traveler's ATK,\n· When Traveler's HP is no less than 50%, 10% of Traveler's Max HP will be consumed to increase DMG inflicted by each Charged Attack hit by 100% of Traveler's ATK.\n· When Traveler's HP is lower than 50%, one instance of healing equal to 25% of Traveler's Max HP will be restored upon hitting an enemy.\n· Charged Attack: Tidebound can be triggered up to once every 15s.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_PlayerWater_07.png"
    }
  ],
  "constellations": [
    {
      "name": "Swelling Lake",
      "description": "Picking up a Sourcewater Droplet will restore 2 Energy to the Traveler.\nYou must first unlock the Ascension Talent \"Spotless Waters.\"",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_PlayerWater_01.png"
    },
    {
      "name": "Trickling Purity",
      "description": "The Movement SPD of Rising Waters' bubble will be decreased by 30%, and its duration increased by 3s.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_PlayerWater_02.png"
    },
    {
      "name": "Turbulent Ripples",
      "description": "Increases the Level of Aquacrest Saber by 3.\nMaximum upgrade level is 15.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_U_PlayerWater_01.png"
    },
    {
      "name": "Pouring Descent",
      "description": "When using Aquacrest Saber, an Aquacrest Aegis that can absorb 10% of the Traveler's Max HP in DMG will be created and will absorb Hydro DMG with 250% effectiveness. It will persist until the Traveler finishes using the skill.\nOnce every 2s, after a Dewdrop hits an opponent, if the Traveler is being protected by Aquacrest Aegis, the DMG Absorption of the Aegis will be restored to 10% of the Traveler's Max HP. If the Traveler is not presently being protected by an Aegis, one will be redeployed.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_PlayerWater_03.png"
    },
    {
      "name": "Churning Whirlpool",
      "description": "Increases the Level of Rising Waters by 3.\nMaximum upgrade level is 15.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_U_PlayerWater_02.png"
    },
    {
      "name": "Tides of Justice",
      "description": "When the Traveler picks up a Sourcewater Droplet, they will restore HP to a nearby party member with the lowest remaining HP percentage based on 6% of said member's Max HP.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_PlayerWater_04.png"
    }
  ],
