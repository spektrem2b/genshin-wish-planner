  "passiveTalents": [
    {
      "name": "Conqueror of Evil: Tamer of Demons",
      "description": "While under the effects of Bane of All Evil, all DMG dealt by Xiao increases by 5%. DMG increases by a further 5% for every 3s the ability persists.\nThe maximum DMG Bonus is 25%.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Xiao_05.png"
    },
    {
      "name": "Dissolution Eon: Heaven Fall",
      "description": "Using Lemniscatic Wind Cycling increases the DMG of subsequent uses of Lemniscatic Wind Cycling by 15%.\nThis effect lasts for 7s, and has a maximum of 3 stacks. Gaining a new stack refreshes the effect's duration.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Xiao_06.png"
    },
    {
      "name": "Transcension: Gravity Defier",
      "description": "Decreases climbing Stamina consumption for your own party members by 20%.\nNot stackable with Passive Talents that provide the exact same effects.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_Explosion_Climb.png"
    }
  ],
