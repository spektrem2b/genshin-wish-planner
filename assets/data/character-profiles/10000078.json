  "passiveTalents": [
    {
      "name": "Four-Causal Correction",
      "description": "When Alhaitham's Charged or Plunging Attacks hit opponents, they will generate 1 Chisel-Light Mirror. This effect can be triggered once every 12s.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Alhatham_05.png"
    },
    {
      "name": "Mysteries Laid Bare",
      "description": "Each point of Alhaitham's Elemental Mastery will increase the DMG dealt by Projection Attacks and Particular Field: Fetters of Phenomena by 0.1%.\nThe DMG of both aforementioned abilities can be increased by a maximum of 100% this way.",
      "icon": "https://gi.yatta.moe/assets/UI/UI_Talent_S_Alhatham_06.png"
